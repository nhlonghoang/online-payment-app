@model Category

<form method="post">
	<input asp-for="Id" hidden />
	<div class="border-secondary p-3 mt-4">
		<div class="row">
			<h2 class="text-primary p-0">Delete Category</h2>
			<hr class="border-1 ">
		</div>
		<div class="row mt-2">
			<label asp-for=Name class="p-0"></label>
			<input asp-for=Name class="form-control" disabled/>
		</div>
		<div class="row mt-2">
			<label asp-for=DisplayOrder class="p-0"></label>
			<input asp-for=DisplayOrder class="form-control" disabled />
		</div>
		<div class="row mt-2">
			<div class="col-6 col-md-3 mt-2">
				<button type="submit" class="btn btn-danger form-control">Delete</button>
			</div>
			<div class="col-6 col-md-3 mt-2">
				<a asp-controller="Category" asp-action="Index" class="btn btn-secondary btn-outline-light form-control">
					Back To List
				</a>
			</div>
		</div>
	</div>
</form>
