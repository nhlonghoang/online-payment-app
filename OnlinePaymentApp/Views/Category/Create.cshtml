@model Category

<form method="post">
	<div class="border-secondary p-3 mt-4">
		<div class="row">
			<h2 class="text-primary p-0">Create Category</h2>
			<hr class="border-1 ">
		</div>
		<div class="row mt-2">
			<label asp-for=Name class="p-0"></label>
			<input asp-for=Name class="form-control" />
			<span asp-validation-for="Name" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=DisplayOrder class="p-0"></label>
			<input asp-for=DisplayOrder class="form-control" />
			<span asp-validation-for="DisplayOrder" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<div class="col-6 col-md-3 mt-2">
				<button type="submit" class="btn btn-primary form-control">Create</button>
			</div>
			<div class="col-6 col-md-3 mt-2">
				<a asp-controller="Category" asp-action="Index" class="btn btn-secondary btn-outline-light form-control">
					Back To List
				</a>
			</div>
		</div>
	</div>
</form>