@model ProductVM

<form method="post">
	<div asp-validation-summary="All"></div> 
	<div class="border-secondary p-3 mt-4">
		<div class="row">
			<h2 class="text-primary p-0">Create Product</h2>
			<hr class="border-1 ">
		</div>
		<div class="row mt-2">
			<label asp-for=Product.Title class="p-0"></label>
			<input asp-for=Product.Title class="form-control" />
			<span asp-validation-for="Product.Title" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<textarea class="form-control" asp-for=Product.Description class="p-0"></textarea>
			<span asp-validation-for="Product.Description" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.ISBN class="p-0"></label>
			<input asp-for=Product.ISBN class="form-control" />
			<span asp-validation-for="Product.ISBN" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.Author class="p-0"></label>
			<input asp-for=Product.Author class="form-control" />
			<span asp-validation-for="Product.Author" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.ListPrice class="p-0"></label>
			<input asp-for=Product.ListPrice class="form-control" />
			<span asp-validation-for="Product.ListPrice" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.Price class="p-0"></label>
			<input asp-for=Product.Price class="form-control" />
			<span asp-validation-for="Product.Price" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.Price50 class="p-0"></label>
			<input asp-for=Product.Price50 class="form-control" />
			<span asp-validation-for="Product.Price50" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.Price100 class="p-0"></label>
			<input asp-for=Product.Price100 class="form-control" />
			<span asp-validation-for="Product.Price100" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.CategoryId class="p-0"></label>
			<span asp-validation-for="Product.CategoryId" class="text-danger"></span>
			<select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-select">
				<option disabled selected>--Select category--</option>
			</select>
		</div>
		<div class="row mt-2">
			<label asp-for=Product.ImageUrl class="p-0"></label>
			<input asp-for=Product.ImageUrl class="form-control" />
			<span asp-validation-for="Product.ImageUrl" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<div class="col-6 col-md-3 mt-2">
				<button type="submit" class="btn btn-primary form-control">Create</button>
			</div>
			<div class="col-6 col-md-3 mt-2">
				<a asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-outline-light form-control">
					Back To List
				</a>
			</div>
		</div>
	</div>
</form>


			@section Scripts{
				@{
					/*
					 * Automatically find the name in Shared folder because the partial tag
					 * this automatically generate script validation for client side following serverside validation only.
					 * Doesn't work with custom validation
					 */
					<partial name="_ValidationScriptsPartial" /> 
				}
			}