@model Product

<form method="post">
	<div asp-validation-summary="All"></div> 
	<div class="border-secondary p-3 mt-4">
		<div class="row">
			<h2 class="text-primary p-0">Create Product</h2>
			<hr class="border-1 ">
		</div>
		<div class="row mt-2">
			<label asp-for=Title class="p-0"></label>
			<input asp-for=Title class="form-control" />
			<span asp-validation-for="Title" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<textarea asp-for=Description class="p-0"></textarea>
			<input asp-for=Description class="form-control" />
			<span asp-validation-for="Description" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=ISBN class="p-0"></label>
			<input asp-for=ISBN class="form-control" />
			<span asp-validation-for="ISBN" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Author class="p-0"></label>
			<input asp-for=Author class="form-control" />
			<span asp-validation-for="Author" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=ListPrice class="p-0"></label>
			<input asp-for=ListPrice class="form-control" />
			<span asp-validation-for="ListPrice" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Price class="p-0"></label>
			<input asp-for=Price class="form-control" />
			<span asp-validation-for="Price" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Price50 class="p-0"></label>
			<input asp-for=Price50 class="form-control" />
			<span asp-validation-for="Price50" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<label asp-for=Price100 class="p-0"></label>
			<input asp-for=Price100 class="form-control" />
			<span asp-validation-for="Price100" class="text-danger"></span>
		</div>
		<div class="row mt-2">
			<div class="col-6 col-md-3 mt-2">
				<button type="submit" class="btn btn-primary form-control">Create</button>
			</div>
			<div class="col-6 col-md-3 mt-2">
				<a asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-outline-light form-control">
					Back To List
				</a>
			</div>
		</div>
	</div>
</form>


			@section Scripts{
				@{
					/*
					 * Automatically find the name in Shared folder because the partial tag
					 * this automatically generate script validation for client side following serverside validation only.
					 * Doesn't work with custom validation
					 */
					<partial name="_ValidationScriptsPartial" /> 
				}
			}