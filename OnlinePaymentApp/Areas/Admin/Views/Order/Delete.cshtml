@model Product

<form method="post">
	<input asp-for="Id" hidden />
	<div class="border-secondary p-3 mt-4">
		<div class="row">
			<h2 class="text-primary p-0">Delete Product</h2>
			<hr class="border-1 ">
		</div>
		<div class="row mt-2">
			<label asp-for=Title class="p-0"></label>
			<input asp-for=Title class="form-control" disabled/>
		</div>
		<div class="row mt-2">
			<label asp-for=Description class="p-0"></label>
			<input asp-for=Description class="form-control" disabled />
		</div>
		<div class="row mt-2">
			<label asp-for=Author class="p-0"></label>
			<input asp-for=Author class="form-control" disabled />
		</div>
		<div class="row mt-2">
			<label asp-for=ListPrice class="p-0"></label>
			<input asp-for=ListPrice class="form-control" disabled />
		</div>
		<div class="row mt-2">
			<label asp-for=Price class="p-0"></label>
			<input asp-for=Price class="form-control" disabled />
		</div>
		<div class="row mt-2">
			<label asp-for=Price50 class="p-0"></label>
			<input asp-for=Price50 class="form-control" disabled />
		</div>
		<div class="row mt-2">
			<label asp-for=Price100 class="p-0"></label>
			<input asp-for=Price100 class="form-control" disabled />
		</div>
		<div class="row mt-2">
			<div class="col-6 col-md-3 mt-2">
				<button type="submit" class="btn btn-danger form-control">Delete</button>
			</div>
			<div class="col-6 col-md-3 mt-2">
				<a asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-outline-light form-control">
					Back To List
				</a>
			</div>
		</div>
	</div>
</form>
